MOMENTUM_APP_NAME=Momentum
MOMENTUM_APP_VERSION=0.1.0
MOMENTUM_API_V1_PREFIX=/api/v1
MOMENTUM_DATABASE_URL=sqlite:///data/momentum.db
MOMENTUM_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Leave unset in dev: Vite proxies /api to the backend (see VITE_PROXY_TARGET in docker-compose.yml).
# Set only when bypassing the proxy, e.g. VITE_API_BASE_URL=http://localhost:8000
